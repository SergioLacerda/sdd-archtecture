# .spec.config — SPEC Architecture Configuration
# 
# This file tells agents and tooling where to find the SPEC framework.
# Copy this template to any project and edit the [spec] section.
#
# Usage:
#   python docs/ia/SCRIPTS/setup-wizard.py  (reads this file automatically)

[spec]
# Caminho relativo ou absoluto para spec-architecture
# Exemplos:
#   ../spec-architecture          (irmão em /home/sergio/dev/)
#   /absolute/path/spec-architecture
#   ~/workspace/spec-architecture
spec_path = .

# Versão mínima requerida do SPEC
min_version = 2.1

# Modo de descoberta (local, remote, auto)
discovery_mode = local

[repository]
# Nome do projeto (para logs, métricas, relatórios)
name = spec-architecture

# Linguagem principal (python, go, rust, typescript, etc)
language = python

# Tipo de projeto (app, lib, service, framework, monorepo)
project_type = framework

[paths]
# Diretório onde testes de compliance SPEC ficam
spec_compliance_tests = tests/specs-ia-units

# Diretório com scripts SPEC (usado por agents)
spec_scripts_path = docs/ia/SCRIPTS

# Diretório com regras SPEC (obrigatório, não mudar)
spec_canonical = docs/ia/CANONICAL

[metadata]
# Versão atual do framework
version = 2.1

# Data de última atualização
updated_at = 2026-04-19

# Mantedor/owner do projeto
maintained_by = sergio@dev.local
