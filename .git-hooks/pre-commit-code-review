#!/bin/bash
# Pre-commit Hook: Enforce CODE REVIEW Guardrail (ADR-008)
#
# Purpose: Prevent "lixo" (broken code) from reaching production
# Rule: Agent NEVER auto-commits - must use WIP branch + PR workflow
#
# This hook runs before ANY commit and enforces:
#   1. Cannot commit directly to main (must be on WIP branch)
#   2. Cannot commit critical files without review
#   3. Commits must reference design/spec documents
#   4. Test suite must pass before commit
#
# Installation: cp .git-hooks/pre-commit-code-review .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

REPO_ROOT=$(git rev-parse --show-toplevel)
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
STAGED_FILES=$(git diff --cached --name-only)

echo "🔍 CODE REVIEW Guardrail Check (ADR-008)"
echo "   Branch: $CURRENT_BRANCH"
echo ""

# ============================================================================
# CHECK 1: Cannot commit to main without review
# ============================================================================

if [ "$CURRENT_BRANCH" = "main" ]; then
    echo "❌ BLOCKED: Cannot commit directly to main branch"
    echo ""
    echo "   Workflow (ADR-008):"
    echo "   1. Create WIP branch: git checkout -b wip/feature-<name>"
    echo "   2. Make changes on WIP branch"
    echo "   3. Push: git push origin wip/feature-<name>"
    echo "   4. Create PR in GitHub/GitLab"
    echo "   5. Request architect review"
    echo "   6. Architect merges after approval"
    echo ""
    exit 1
fi

# ============================================================================
# CHECK 2: Warn if commit message doesn't reference design/spec
# ============================================================================

COMMIT_MSG=$(git diff --cached --name-only | head -1)
COMMIT_FILE=".git/COMMIT_EDITMSG"

if [ -f "$COMMIT_FILE" ]; then
    MSG=$(cat "$COMMIT_FILE")
    
    # If significant changes, should reference ADR/design
    if echo "$MSG" | grep -q "feat\|fix\|refactor" && ! echo "$MSG" | grep -qE "FEATURE_DESIGN|ADR|COMPONENT|Ref:"; then
        echo "⚠️  WARNING: Commit message should reference design/spec"
        echo "   Examples:"
        echo "   - feat: Implement RTK patterns (see FEATURE_DESIGN_rtk.md)"
        echo "   - fix: Respect ADR-007 guardrails"
        echo "   - Ref: COMPONENT_compilation.md"
        echo ""
        # Continue anyway, but warn
    fi
fi

# ============================================================================
# CHECK 3: Critical files require special review
# ============================================================================

CRITICAL_FILES=(
    "EXECUTION/spec/CANONICAL/decisions/ADR-007-implementation-guardrails-design-first.md"
    "EXECUTION/spec/CANONICAL/decisions/ADR-008-code-review-governance.md"
    ".sdd-migration/phase-archive/DECISIONS.md"
    ".sdd-migration/PHASES.md"
)

for critical_file in "${CRITICAL_FILES[@]}"; do
    if echo "$STAGED_FILES" | grep -q "^$critical_file$"; then
        echo "⚠️  WARNING: Modifying critical file: $critical_file"
        echo "   This requires architect review and backup!"
        echo "   Make sure you have a backup before merging."
        echo ""
    fi
done

# ============================================================================
# CHECK 4: Tests should pass (if available)
# ============================================================================

if [ -d "$REPO_ROOT/EXECUTION/tests" ]; then
    # Run quick syntax check
    if python -m py_compile "$REPO_ROOT/EXECUTION/tests/test_guardrail_code_review.py" 2>/dev/null; then
        echo "✅ Guardrail tests exist and are valid"
    else
        echo "⚠️  WARNING: Guardrail tests not valid"
    fi
fi

# ============================================================================
# FINAL CHECK: Confirm this is WIP branch (not main)
# ============================================================================

if [[ $CURRENT_BRANCH == "wip/"* ]] || [[ $CURRENT_BRANCH == "feature/"* ]] || [[ $CURRENT_BRANCH == "fix/"* ]]; then
    echo "✅ Branch OK: $CURRENT_BRANCH"
    echo "✅ Commit will be on development branch (not main)"
    echo "✅ Remember: This will require architect PR review before merging to main"
    echo ""
else
    echo "⚠️  INFO: Committing to branch: $CURRENT_BRANCH"
    echo "   Make sure this is intentional"
    echo "   (Must be on WIP/feature/fix branch for architect review workflow)"
    echo ""
fi

echo "✅ Pre-commit checks passed"
echo ""
echo "📋 Next steps:"
echo "   1. Commit to this WIP branch (allowed)"
echo "   2. Push to origin: git push origin $CURRENT_BRANCH"
echo "   3. Create PR on GitHub/GitLab"
echo "   4. Wait for architect review"
echo "   5. Architect will merge after approval"
echo ""

exit 0
