# .sdd.config — SDD Framework Configuration
# 
# This file tells agents and tooling where to find the SDD framework.
# Copy this template to any project and edit the [sdd] section.
#
# Usage:
#   sdd governance generate (generates agent seeds)
#   Projects copy this file and configure spec_path to point to framework

[sdd]
# Relative or absolute path to sdd-architecture (this framework)
# Examples:
#   ../sdd-architecture          (sibling in /home/sergio/dev/)
#   /absolute/path/sdd-architecture
#   ~/workspace/sdd-architecture
spec_path = .

# Minimum required SDD version
min_version = 3.0

# Discovery mode (local, remote, auto)
discovery_mode = local

[repository]
# Project name (for logs, metrics, reports)
name = sdd-architecture

# Primary language (python, go, rust, typescript, etc)
language = python

# Project type (app, lib, service, framework, monorepo)
project_type = framework

[paths]
# Directory with SDD CLI and tooling
sdd_core_path = .sdd-core

# Directory with SDD integration guides and templates
sdd_integration_path = .sdd-integration

# Directory with SDD governance specifications
sdd_canonical = .sdd-core/spec/CANONICAL

[metadata]
# Current framework version
version = 3.0

# Last update date
updated_at = 2026-04-22

# Project maintainer/owner
maintained_by = sergio@dev.local
